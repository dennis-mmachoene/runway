# Copy this file to `.env.local` and fill in real values. See SETUP.md for how
# to obtain each one. `.env.local` is gitignored; this example file is committed.
#
# Runway uses Supabase's CURRENT API keys (publishable + secret). The legacy
# anon / service_role JWTs are deprecating end of 2026 — do not use them.

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ─── Google Gemini (server-only) ───────────────────────────────────────────
GEMINI_API_KEY=

# ─── Runway ────────────────────────────────────────────────────────────────
# Auth is password + mandatory TOTP — no email is ever sent.
OWNER_EMAIL=
# Used only by the seed script to set the owner's password.
OWNER_PASSWORD=
